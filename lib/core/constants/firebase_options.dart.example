import 'package:firebase_core/firebase_core.dart' show FirebaseOptions;
import 'package:flutter/foundation.dart'
    show defaultTargetPlatform, TargetPlatform;

class DefaultFirebaseOptions {
  /// Returns the [FirebaseOptions] for the current platform.
  static FirebaseOptions get currentPlatform {
    switch (defaultTargetPlatform) {
      case TargetPlatform.android:
        return android;
      case TargetPlatform.iOS:
        return ios;
      default:
        throw UnsupportedError(
          'DefaultFirebaseOptions are not configured for this platform.',
        );
    }
  }

  // ---------------------------------------------------------------------------
  // Android
  // ---------------------------------------------------------------------------

  /// Firebase options for Android.
  ///
  /// These values come from `google-services.json` and are embedded here by
  /// the FlutterFire CLI so that Firebase can be initialised in pure Dart.
  static const FirebaseOptions android = FirebaseOptions(
    apiKey: 'YOUR_ANDROID_API_KEY', // Web API key from Firebase console
    appId: 'YOUR_ANDROID_APP_ID', // mobilesdk_app_id from google-services.json
    messagingSenderId: 'YOUR_SENDER_ID', // project_number from google-services.json
    projectId: 'YOUR_PROJECT_ID', // project_id from google-services.json
    storageBucket: 'YOUR_STORAGE_BUCKET', // storage_bucket from google-services.json
  );

  // ---------------------------------------------------------------------------
  // iOS
  // ---------------------------------------------------------------------------

  /// Firebase options for iOS.
  ///
  /// These values come from `GoogleService-Info.plist` and are embedded here by
  /// the FlutterFire CLI so that Firebase can be initialised in pure Dart.
  static const FirebaseOptions ios = FirebaseOptions(
    apiKey: 'YOUR_IOS_API_KEY', // API_KEY from GoogleService-Info.plist
    appId: 'YOUR_IOS_APP_ID', // GOOGLE_APP_ID from GoogleService-Info.plist
    messagingSenderId: 'YOUR_SENDER_ID', // GCM_SENDER_ID from GoogleService-Info.plist
    projectId: 'YOUR_PROJECT_ID', // PROJECT_ID from GoogleService-Info.plist
    storageBucket: 'YOUR_STORAGE_BUCKET', // STORAGE_BUCKET from GoogleService-Info.plist
    iosBundleId: 'YOUR_IOS_BUNDLE_ID', // BUNDLE_ID from GoogleService-Info.plist
  );
}
