rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Agent profile photos
    // Any logged-in agent can read (needed for public profiles)
    // Only the owning agent can write their own avatar
    match /avatars/{userId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null 
        && request.auth.uid == userId;
    }

    // Player photos
    // Only the owning agent can read and write
    // We can't query Firestore from Storage rules so we
    // scope access by requiring authentication and checking
    // the path — Firestore rules handle the ownership check
    match /players/{playerId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Player documents
    match /players/{playerId}/documents/{documentId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Market post photos
    // Any logged-in agent can read (needed for the Market feed)
    // Any logged-in agent can write (Firestore rules enforce ownership)
    match /market_posts/{postId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
  }
}