# =============================================================================
# Launchpad — Environment Variables
# =============================================================================
# Copy this file to .env.development (or .env.production) and fill in values.
# These files are gitignored and must NEVER be committed.
# =============================================================================

# BASE_URL — Root URL for the backend API (no trailing slash).
# Used by Dio for all HTTP requests.
# Example: https://api.example.com/v1
BASE_URL=https://your.api.url.here
